# ---------------------------------------------------------------------------
# Shared configuration
# ---------------------------------------------------------------------------

# Public Supabase config (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Public base URL for the API (used by the web app to call the backend)
NEXT_PUBLIC_API_URL=http://localhost:4000

# Public site URL (used for documentation snippets, OAuth redirects, etc.)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# API backend (server-only)
# ---------------------------------------------------------------------------

# Supabase service role key — NEVER expose to the browser
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Redis connection string. Use redis://localhost:6379 with docker-compose.
REDIS_URL=redis://localhost:6379

# Session encryption key (32+ chars). Generate with: openssl rand -hex 32
SESSION_ENCRYPTION_KEY=please-change-me-to-a-random-32-byte-hex-string

# Webhook signing secret default (per-tenant secrets are generated, but a
# global pepper protects against secret-leak replay attacks).
WEBHOOK_SIGNING_PEPPER=please-change-me-too

# API server port + CORS origin (comma-separated list of allowed origins)
API_PORT=4000
API_CORS_ORIGINS=http://localhost:3000

# Where Baileys auth state should be persisted on disk
WHATSAPP_SESSIONS_DIR=./sessions

# OTP defaults
OTP_DEFAULT_LENGTH=6
OTP_DEFAULT_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=30

# Rate limits (requests per minute, per API key)
RATE_LIMIT_SEND_PER_MIN=20
RATE_LIMIT_VERIFY_PER_MIN=60
